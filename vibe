#!/usr/bin/env bash

set -e

tolower() {
  echo "$1" | tr '[:upper:]' '[:lower:]'
}

free_port() {
  python3 -c 'import socket,random
while True:
 p=random.randint(20000,60000)
 s=socket.socket()
 try: s.bind(("127.0.0.1",p)); s.close(); print(p); break
 except: s.close()'
}

IS_MACOS=0
[[ "$(uname -s)" == "Darwin" ]] && IS_MACOS=1

# Default modes
DEBUG=0
BUILD=0
DOWN=0
KEEP=0
TORN_DOWN=0
VSCODE=0
NO_CACHE=0
GITIGNORE_ON=0
GITIGNORE_OFF=0
QUERY=0
ISOLATED=0
QUERY_PROMPT=""
PARENT_DIR=""

usage() {
  cat <<'EOF'
Usage: vibe [flags] [directory] [-- args...]

Flags:
  -B    Build the container image before starting
  -d    Tear down the container and exit
  -D    Debug mode (shell into the container)
  -g    Force .claude/.gitignore on (add '*' entry)
  -G    Force .claude/.gitignore off (remove '*' entry)
  -h    Show this help message
  -k    Keep container running on exit
  -N    Build with no cache (implies -B)
  -P    Mount parent directory read-only for sibling repo access
  -q P  Query one-off: run prompt P non-interactively, print result to stdout
  -Q P  Like -q but isolated: only login credentials mounted, no sockets, and a
        throwaway container so it can run alongside an existing one
  -v    Open VS Code attached to the container
EOF
  exit 0
}

# Parse flags
while getopts "BdDgGhkNP:Q:q:v" opt; do
  case $opt in
    B) BUILD=1;;
    d) DOWN=1;;
    D) DEBUG=1;;
    g) GITIGNORE_ON=1;;
    G) GITIGNORE_OFF=1;;
    h) usage;;
    k) KEEP=1;;
    N) NO_CACHE=1; BUILD=1;;
    P) PARENT_DIR="$(realpath -- "$OPTARG")";;
    q) QUERY=1; QUERY_PROMPT="$OPTARG";;
    Q) ISOLATED=1; QUERY_PROMPT="$OPTARG";;
    v) VSCODE=1;;
    *) usage;;
  esac
done
shift $((OPTIND - 1))

# Image build definitions, hoisted so an isolated query (-Q) can build the
# base image before any project or socket setup runs below.
IMAGE_NAME="vibe-base"
ENTRYPOINT_SCRIPT='#!/bin/bash

if [[ -n "${SSH_RELAY_PORT:-}" ]]; then
  rm -f /tmp/ssh_auth_sock
  socat UNIX-LISTEN:/tmp/ssh_auth_sock,fork,mode=666 \
    TCP:host.docker.internal:${SSH_RELAY_PORT} &
  export SSH_AUTH_SOCK=/tmp/ssh_auth_sock
elif [[ -S /tmp/ssh_auth_sock ]]; then
  sudo chmod 666 /tmp/ssh_auth_sock
  export SSH_AUTH_SOCK=/tmp/ssh_auth_sock
fi

if [[ -n "${GPG_RELAY_PORT:-}" ]]; then
  gpgconf --kill gpg-agent 2>/dev/null || true
  GNUPG_SOCK=$(gpgconf --list-dir agent-socket)
  mkdir -m 700 -p "$(dirname "$GNUPG_SOCK")"
  rm -f "$GNUPG_SOCK"
  socat UNIX-LISTEN:"${GNUPG_SOCK}",fork,mode=600 \
    TCP:host.docker.internal:${GPG_RELAY_PORT} &
elif [[ -S /tmp/gnupg_sock ]]; then
  sudo chmod 666 /tmp/gnupg_sock
  gpgconf --kill gpg-agent 2>/dev/null || true
  GNUPG_SOCK=$(gpgconf --list-dir agent-socket)
  mkdir -m 700 -p "$(dirname "$GNUPG_SOCK")"
  ln -sf /tmp/gnupg_sock "$GNUPG_SOCK"
fi

if [[ -n "${GPG_PUBKEYS:-}" && ! -f /tmp/.gpg_keys_imported ]]; then
  gpgconf --kill keyboxd 2>/dev/null || true
  echo "$GPG_PUBKEYS" | gpg --batch --no-autostart --import 2>/dev/null || true
  gpg --batch --no-autostart --list-keys --with-colons 2>/dev/null \
    | awk -F: '"'"'/^fpr:/{print $10":6:"}'"'"' \
    | gpg --batch --no-autostart --import-ownertrust 2>/dev/null || true
  gpgconf --kill keyboxd 2>/dev/null || true
  touch /tmp/.gpg_keys_imported
fi

if [[ -f /tmp/host_gitconfig ]]; then
  ln -sf /tmp/host_gitconfig "$HOME/.gitconfig"
fi

if [[ -f /tmp/host_claude_json ]]; then
  ln -sf /tmp/host_claude_json "$HOME/.claude.json"
else
  if [[ ! -f "$HOME/.claude/claude.json" ]]; then
    echo '"'"'{}'"'"' > "$HOME/.claude/claude.json"
  fi
  ln -sf "$HOME/.claude/claude.json" "$HOME/.claude.json"
fi

if [[ "${VIBE_VSCODE:-}" == "1" ]]; then
  mkdir -p /tmp/vscode_queue /tmp/vscode_resp
fi
if [[ "${VIBE_BROWSER:-}" == "1" ]]; then
  mkdir -p /tmp/browser_queue
fi
if [[ "${VIBE_CLIPBOARD:-}" == "1" ]]; then
  mkdir -p /tmp/clipboard_queue /tmp/clipboard_resp
fi

if [[ -p /tmp/vscode_fifo ]] || [[ -d /tmp/vscode_queue ]]; then
  export EDITOR="code -w"
fi

if [[ -p /tmp/browser_fifo ]] || [[ -d /tmp/browser_queue ]]; then
  export BROWSER="xdg-open"
fi

node -e "
  var fs = require('"'"'fs'"'"'), f = process.env.HOME + '"'"'/.claude.json'"'"';
  var d = JSON.parse(fs.readFileSync(f, '"'"'utf8'"'"'));
  var p = d.projects = d.projects || {}, dir = process.cwd();
  if (!p[dir] || !p[dir].hasTrustDialogAccepted) {
    p[dir] = Object.assign(p[dir] || {}, {hasTrustDialogAccepted: true, hasCompletedProjectOnboarding: true});
    fs.writeFileSync(f, JSON.stringify(d, null, 2));
  }
" 2>/dev/null || true

if [[ -n "${WORKDIR:-}" ]]; then
  sudo mkdir -p "$WORKDIR" && sudo chown $(id -u):$(id -g) "$WORKDIR" 2>/dev/null || true
  cd "$WORKDIR"
fi

if [[ -n "${ON_BUILD:-}" && ! -f /tmp/.on_build_done ]]; then
  eval "$ON_BUILD"
  touch /tmp/.on_build_done
fi


exec "$@"
'

CODE_WRAPPER='#!/bin/bash
ARGS=()
WAIT=0
for arg in "$@"; do
  if [[ "$arg" == "-w" || "$arg" == "--wait" ]]; then
    WAIT=1
    ARGS+=("$arg")
  elif [[ "$arg" == -* ]]; then
    ARGS+=("$arg")
  else
    ARGS+=("$(realpath "$arg")")
  fi
done
if [[ -d /tmp/vscode_queue ]]; then
  ID="$$.$RANDOM"
  printf '"'"'%s\0'"'"' "${ARGS[@]}" > "/tmp/vscode_queue/${ID}"
  if [[ "$WAIT" -eq 1 ]]; then
    for _ in $(seq 1 300); do
      [[ -f "/tmp/vscode_resp/${ID}" ]] && { rm -f "/tmp/vscode_resp/${ID}"; exit 0; }
      sleep 0.1
    done
  fi
elif [[ -p /tmp/vscode_fifo ]]; then
  printf '"'"'%s\0'"'"' "${ARGS[@]}" > /tmp/vscode_fifo
  if [[ "$WAIT" -eq 1 ]]; then
    read -r < /tmp/vscode_fifo_resp
  fi
fi
'

BROWSER_WRAPPER='#!/bin/bash
for arg in "$@"; do
  if [[ -d /tmp/browser_queue ]]; then
    echo "$arg" > "/tmp/browser_queue/$$.$RANDOM"
  elif [[ -p /tmp/browser_fifo ]]; then
    echo "$arg" > /tmp/browser_fifo
  fi
done
'

CLIPBOARD_WRAPPER='#!/bin/bash
IPC=""
if [[ -d /tmp/clipboard_queue ]]; then
  IPC=queue
elif [[ -p /tmp/clipboard_fifo ]]; then
  IPC=fifo
elif [[ -S /tmp/clip.sock ]]; then
  IPC=socket
fi
TYPE="image/png"
IS_READ=0
LIST=0
case "$(basename "$0")" in wl-paste) IS_READ=1 ;; esac
while [[ $# -gt 0 ]]; do
  case "$1" in
    -o|--output) IS_READ=1; shift ;;
    -l|--list-types) LIST=1; IS_READ=1; shift ;;
    -t|--type) TYPE="$2"; shift 2 ;;
    *) shift ;;
  esac
done
((IS_READ)) || exit 0

[[ -n "$IPC" ]] || exit 1

ID="$$.$RANDOM"
if ((LIST)) || [[ "$TYPE" == "TARGETS" ]]; then
  REQ="LIST"
else
  REQ="$TYPE"
fi
if [[ "$IPC" == "socket" ]]; then
  printf "%s\n" "$REQ" | socat - UNIX-CONNECT:/tmp/clip.sock 2>/dev/null
  exit $?
fi
if [[ "$IPC" == "queue" ]]; then
  echo "$REQ" > "/tmp/clipboard_queue/${ID}"
else
  echo "${ID} ${REQ}" > /tmp/clipboard_fifo
fi
RESP="/tmp/clipboard_resp/${ID}"
for _ in $(seq 1 50); do
  [[ -f "$RESP" ]] && { cat "$RESP"; rm -f "$RESP"; exit 0; }
  sleep 0.1
done
exit 1
'

read -r -d '' DOCKERFILE <<'DOCKERFILE_EOF' || true
FROM debian:latest

RUN apt-get update -y \
  && apt-get upgrade -y \
  && apt-get install -y --no-install-recommends \
    curl build-essential git sudo docker.io openssh-client gnupg nodejs npm python3 python3-dev iproute2 socat \
  && rm -rf /var/lib/apt/lists/*

ENV USER=dev
ENV GIT_SSH_COMMAND="ssh -o StrictHostKeyChecking=no"
ARG UID=1000
ARG GID=1000
RUN groupdel $(getent group $GID | cut -d: -f1) 2>/dev/null || true \
  && groupadd -g $GID $USER \
  && useradd -mG sudo -g $USER -s /bin/bash -u $UID $USER \
  && echo "$USER ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/$USER

USER $USER
WORKDIR /tmp

RUN mkdir -p \
  /home/$USER/.local/bin \
  /home/$USER/.local/state/claude \
  /home/$USER/.claude

RUN curl -fsSL https://claude.ai/install.sh | bash \
  && curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/home/$USER/.local/bin:$PATH"

# printf, not echo: RUN uses dash, whose echo eats backslash escapes and
# corrupts any wrapper containing them.
ARG CODE_WRAPPER
RUN printf '%s\n' "$CODE_WRAPPER" > /home/$USER/.local/bin/code \
  && chmod +x /home/$USER/.local/bin/code

ARG BROWSER_WRAPPER
RUN printf '%s\n' "$BROWSER_WRAPPER" > /home/$USER/.local/bin/xdg-open \
  && chmod +x /home/$USER/.local/bin/xdg-open

ARG CLIPBOARD_WRAPPER
RUN printf '%s\n' "$CLIPBOARD_WRAPPER" > /home/$USER/.local/bin/xclip \
  && chmod +x /home/$USER/.local/bin/xclip \
  && ln -s xclip /home/$USER/.local/bin/xsel \
  && ln -s xclip /home/$USER/.local/bin/wl-paste

ARG ENTRYPOINT
RUN printf '%s\n' "$ENTRYPOINT" | sudo tee /entrypoint.sh > /dev/null \
  && sudo chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]

CMD ["bash", "-c", "sleep infinity"]
DOCKERFILE_EOF

build_image() {
  docker build -t "$IMAGE_NAME" \
    --build-arg "UID=$(id -u)" \
    --build-arg "GID=$(id -g)" \
    --build-arg "ENTRYPOINT=$ENTRYPOINT_SCRIPT" \
    --build-arg "CODE_WRAPPER=$CODE_WRAPPER" \
    --build-arg "BROWSER_WRAPPER=$BROWSER_WRAPPER" \
    --build-arg "CLIPBOARD_WRAPPER=$CLIPBOARD_WRAPPER" \
    "$@" - <<< "$DOCKERFILE"
}

# Isolated one-off query: reuse only the login credentials, mount nothing else,
# and run a throwaway --rm container so it sits alongside any existing vibe
# container in the same directory. Skips all project/socket setup below.
if ((ISOLATED)); then
  if ! docker image inspect "$IMAGE_NAME" &>/dev/null; then
    build_image >&2
  fi
  CLAUDE_HOME="${HOME}/.claude"
  CLAUDE_JSON="${HOME}/.claude.json"
  mkdir -p "$CLAUDE_HOME"
  [[ -f "$CLAUDE_JSON" ]] || echo '{}' > "$CLAUDE_JSON"
  exec docker run --rm \
    -v "${CLAUDE_JSON}:/tmp/host_claude_json" \
    -v "${CLAUDE_HOME}:/home/dev/.claude" \
    "$IMAGE_NAME" claude -p "$QUERY_PROMPT" --dangerously-skip-permissions < /dev/null
fi

# Split positional args at -- separator
WORKTREE=""
WORKTREE_BRANCH=""
EXTRA_ARGS=()
if [[ "${1:-}" == "--" ]]; then
  # No directory arg, rest goes to tool
  shift
  EXTRA_ARGS=("$@")
  TARGET_DIR="$PWD"
elif [[ "${1:-}" == w:* ]]; then
  # Git worktree mode: create/reuse a worktree under .w/
  WORKTREE_BRANCH="${1#w:}"
  WORKTREE_BASE="$(git rev-parse --show-toplevel)/.w"

  mkdir -p "$WORKTREE_BASE"
  # Keep worktrees out of the parent repo, same convention as .claude/
  [[ -f "$WORKTREE_BASE/.gitignore" ]] || echo '*' > "$WORKTREE_BASE/.gitignore"

  WORKTREE="${WORKTREE_BASE}/${WORKTREE_BRANCH}"
  if [[ -d "$WORKTREE" ]] && [[ ! -f "$WORKTREE/.git" ]]; then
    read -rp "Stale directory '$WORKTREE_BRANCH' exists but is not a valid worktree. Remove and re-create? [y/N] " answer
    if [[ "$answer" == [yY] ]]; then
      rm -rf "$WORKTREE"
    else
      echo "Cannot proceed without a valid worktree." >&2
      exit 1
    fi
  fi
  if [[ ! -d "$WORKTREE" ]]; then
    if git show-ref --verify --quiet "refs/heads/$WORKTREE_BRANCH"; then
      git worktree add "$WORKTREE" "$WORKTREE_BRANCH"
    else
      git worktree add -b "$WORKTREE_BRANCH" "$WORKTREE"
    fi
  fi

  # Mount the entire repo so git worktree paths resolve inside the container
  TARGET_DIR="$(git rev-parse --show-toplevel)"
  WORKTREE_REL=".w/${WORKTREE_BRANCH}"
  shift
  if [[ "${1:-}" == "--" ]]; then
    shift
  fi
  EXTRA_ARGS=("$@")
elif [[ -z "${1:-}" ]] || [[ "${1:-}" == -* ]]; then
  # No directory arg; anything remaining is tool args
  TARGET_DIR="$PWD"
  if [[ "${1:-}" == "--" ]]; then
    shift
  fi
  EXTRA_ARGS=("$@")
else
  TARGET_DIR="$(realpath -- "$1")"
  shift
  if [[ "${1:-}" == "--" ]]; then
    shift
  fi
  EXTRA_ARGS=("$@")
fi
if [[ ! -d "$TARGET_DIR" ]]; then
  echo "Error: '$TARGET_DIR' is not a directory" >&2
  exit 1
fi
export TARGET_DIR

if [[ -n "$PARENT_DIR" ]]; then
  if [[ ! -d "$PARENT_DIR" ]]; then
    echo "Error: parent directory '$PARENT_DIR' does not exist" >&2
    exit 1
  fi
  case "$TARGET_DIR" in
    "$PARENT_DIR"/*) ;;
    *) echo "Error: '$TARGET_DIR' is not inside '$PARENT_DIR'" >&2; exit 1;;
  esac
fi

# Ensure .claude/ exists and mount it
if [[ -n "$WORKTREE" ]]; then
  VIBE_DIR="$(git rev-parse --show-toplevel)/.claude"
else
  VIBE_DIR="${TARGET_DIR}/.claude"
fi
VIBE_DIR_EXISTED=0
[[ -d "$VIBE_DIR" ]] && VIBE_DIR_EXISTED=1
mkdir -p "$VIBE_DIR"
GITIGNORE="$VIBE_DIR/.gitignore"
if ((GITIGNORE_ON)); then
  grep -qxF '*' "$GITIGNORE" 2>/dev/null || echo '*' >> "$GITIGNORE"
elif ((GITIGNORE_OFF)); then
  if [[ -f "$GITIGNORE" ]]; then
    sed -i '/^[[:space:]]*\*[[:space:]]*$/d' "$GITIGNORE"
    if ! grep -q '[^[:space:]]' "$GITIGNORE" 2>/dev/null; then
      rm -f "$GITIGNORE"
    fi
  fi
elif ! ((VIBE_DIR_EXISTED)); then
  echo '*' > "$GITIGNORE"
fi
export VIBE_DIR

# Inject/update a managed section in .claude/CLAUDE.md
# Usage: inject_section "## Heading" "content"
inject_section() {
  local heading="$1" content="$2"
  local claude_md="$VIBE_DIR/CLAUDE.md"
  local block
  block="$(printf '%s\n\n%s' "$heading" "$content")"

  if [[ ! -f "$claude_md" ]]; then
    printf '%s\n' "$block" > "$claude_md"
    return
  fi

  if ! grep -qF "$heading" "$claude_md"; then
    printf '\n\n%s\n' "$block" >> "$claude_md"
    return
  fi

  _AWK_HEADING="$heading" _AWK_BLOCK="$block" awk '
    BEGIN { heading=ENVIRON["_AWK_HEADING"]; block=ENVIRON["_AWK_BLOCK"] }
    $0 == heading { skip=1; printf "%s\n\n", block; next }
    skip && /^## / { skip=0 }
    !skip { print }
  ' "$claude_md" > "$claude_md.tmp" && mv "$claude_md.tmp" "$claude_md"
}

# Inject personal rules
read -r -d '' DEFAULT_RULES <<'RULES' || true
- Challenge user decisions when you see a better approach.
- Simple and clean over hacky or overengineered.
- If deviating from the plan, stop and discuss first.
- Small steps: max ~300 lines per step, one reviewable commit each. Ask before the next.
- Comments: max 2 lines, only when why isn't obvious; prefer none. No decorative comments, banners, or ASCII art.
- NEVER commit or push unless the user explicitly says "commit". Suggest a conventional commit message instead. One approval ≠ blanket permission.
- Never push to remote.
RULES

RULES_FILE="$HOME/.claude-docker/rules.md"
if [[ -f "$RULES_FILE" ]]; then
  RULES_CONTENT="$(cat "$RULES_FILE")"
  if echo "$RULES_CONTENT" | grep -q '^##'; then
    echo "Error: $RULES_FILE contains '##' headings which would break the section delimiter" >&2
    exit 1
  fi
else
  RULES_CONTENT="$DEFAULT_RULES"
fi
inject_section "## Personal Rules (maintained by the vibe utility)" "$RULES_CONTENT"

# Inject environment context
read -r -d '' ENV_CONTENT <<'ENV' || true
Disposable Ubuntu Docker container with passwordless sudo. Install freely.
After installing a tool, append its directory to ~/.bin-paths.
At session start, run: export PATH="$(cat ~/.bin-paths 2>/dev/null | tr '\n' ':'):$PATH"

Save project context in .claude/: BACKLOG.md and PROGRESS.md in the branch-scoped directory named in your system prompt; MEMORY.md and per-memory files under .claude/memory/ are shared across all branches. .claude/ is bind-mounted from the parent repo, persists across worktrees. Max 150 lines per file.
ENV
inject_section "## Environment (maintained by the vibe utility)" "$ENV_CONTENT"

# Enforce the rules that prompts can't reliably enforce, via Claude Code hooks.
# Scripts are (re)written each run; only their references are merged into
# .claude/settings.local.json so an existing user config is never clobbered.
HOOKS_DIR="$VIBE_DIR/vibe-hooks"
mkdir -p "$HOOKS_DIR"

cat > "$HOOKS_DIR/prompt_gate.py" <<'PY'
import sys, json, re, os
SENT = "/tmp/vibe-commit-approved"
try:
    prompt = json.load(sys.stdin).get("prompt") or ""
except Exception:
    sys.exit(0)
if re.search(r"\bcommit(s|ted|ting)?\b", prompt, re.I):
    try: open(SENT, "w").close()
    except Exception: pass
else:
    try: os.remove(SENT)
    except OSError: pass
sys.exit(0)
PY

cat > "$HOOKS_DIR/commit_guard.py" <<'PY'
import sys, json, re, os
SENT = "/tmp/vibe-commit-approved"
try:
    cmd = (json.load(sys.stdin).get("tool_input") or {}).get("command") or ""
except Exception:
    sys.exit(0)
subs, toks, i = [], cmd.split(), 0
while i < len(toks):
    if toks[i] == "git" or toks[i].endswith("/git"):
        j = i + 1
        while j < len(toks) and toks[j].startswith("-"):
            j += 1
        if j < len(toks):
            subs.append(toks[j])
        i = j + 1
        continue
    i += 1
if "push" in subs:
    sys.stderr.write("vibe: pushing to a remote is disabled by policy "
                     "(Personal Rules: never push). Ask the user to push manually.")
    sys.exit(2)
if "commit" in subs:
    # Approval is turn-scoped: prompt_gate clears the sentinel on the next
    # user message, so one "commit" request authorizes every commit this turn.
    if os.path.exists(SENT):
        sys.exit(0)
    sys.stderr.write("vibe: commit blocked — the user's latest message did not ask "
                     "for a commit (Personal Rules: never commit unless explicitly "
                     "told). Suggest a conventional-commit message and wait.")
    sys.exit(2)
sys.exit(0)
PY

cat > "$HOOKS_DIR/comment_guard.py" <<'PY'
import sys, json, os, re
CODE = {".js", ".jsx", ".ts", ".tsx", ".py", ".go", ".rs", ".c", ".h", ".cc",
        ".cpp", ".hpp", ".java", ".rb", ".php", ".swift", ".kt", ".scala",
        ".sh", ".bash", ".zsh", ".pl", ".lua", ".sql", ".vue", ".svelte"}
try:
    data = json.load(sys.stdin)
except Exception:
    sys.exit(0)
ti = data.get("tool_input") or {}
path = ti.get("file_path") or ""
if os.path.splitext(path)[1].lower() not in CODE:
    sys.exit(0)
parts = []
if isinstance(ti.get("new_string"), str): parts.append(ti["new_string"])
if isinstance(ti.get("content"), str): parts.append(ti["content"])
for e in ti.get("edits") or []:
    if isinstance(e, dict) and isinstance(e.get("new_string"), str):
        parts.append(e["new_string"])
run = mx = 0
c_block = False
lua_close = None  # e.g. "]]" or "]=]" while inside a Lua --[[ ... ]] comment
for ln in "\n".join(parts).split("\n"):
    s = ln.strip()
    is_comment = False
    if c_block:
        is_comment = True
        if "*/" in s: c_block = False
    elif lua_close is not None:
        is_comment = True
        if lua_close in s: lua_close = None
    elif s.startswith("/*"):
        is_comment = True
        if "*/" not in s: c_block = True
    elif s.startswith("--"):
        is_comment = True
        m = re.match(r"--\[(=*)\[", s)
        if m:
            close = "]" + "=" * len(m.group(1)) + "]"
            if close not in s[m.end():]: lua_close = close
    elif s.startswith(("//", "#")):
        is_comment = True
    if is_comment and s:
        run += 1; mx = max(mx, run)
    else:
        run = 0
if mx > 2:
    base = os.path.basename(path)
    note = (f"vibe reminder: this change wrote a {mx}-line comment block in "
            f"{base}. Personal Rules cap comments at 2 lines. "
            "If you just added it, trim to <=2 lines or drop it when the code is "
            "self-explanatory; ignore this if the comment was pre-existing and "
            "you did not touch it.")
    print(json.dumps({
        "systemMessage": f"vibe: {mx}-line comment in {base} (2-line max) — review it",
        "hookSpecificOutput": {
            "hookEventName": "PostToolUse", "additionalContext": note}}))
sys.exit(0)
PY

# Keep local settings and generated hooks out of git unless already fully ignored.
if ! grep -qxF '*' "$GITIGNORE" 2>/dev/null; then
  for entry in 'settings.local.json' 'vibe-hooks/'; do
    grep -qxF "$entry" "$GITIGNORE" 2>/dev/null || echo "$entry" >> "$GITIGNORE"
  done
fi

VIBE_DIR="$VIBE_DIR" python3 - <<'PY'
import json, os, sys
path = os.path.join(os.environ["VIBE_DIR"], "settings.local.json")
data = {}
if os.path.exists(path):
    try:
        with open(path) as f:
            data = json.load(f) or {}
    except Exception:
        os.replace(path, path + ".bak")
        sys.stderr.write("vibe: existing settings.local.json was unparseable; "
                         "backed up to settings.local.json.bak\n")
        data = {}
if not isinstance(data, dict):
    data = {}
hooks = data.get("hooks")
if not isinstance(hooks, dict):
    hooks = {}
MARK = "vibe-hooks/"
def strip(lst):
    out = []
    for entry in lst or []:

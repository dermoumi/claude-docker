# Run Claude Code in the container
SYSTEM_PROMPT=""

if [[ -n "$WORKTREE" ]]; then
  read -r -d '' _PROMPT <<EOF || true
You are working inside a git worktree for branch '$WORKTREE_BRANCH' at $WORKDIR.
The parent repository is mounted read-only — only this worktree directory and .git/ are writable.
You may read parent files (e.g. to compare against main), but do not attempt to modify them.
EOF
  SYSTEM_PROMPT+="${_PROMPT}"$'\n\n'
fi

# .claude/ is shared across worktrees, so the branch-scoped path can only be
# resolved per-container — baking it into CLAUDE.md would race between sessions.
VIBE_BRANCH="${WORKTREE_BRANCH:-$(git -C "$WORKDIR" branch --show-current 2>/dev/null)}"
VIBE_BRANCH_SLUG="${VIBE_BRANCH:-detached}"
VIBE_BRANCH_SLUG="${VIBE_BRANCH_SLUG//\//-}"
SYSTEM_PROMPT+="BACKLOG.md and PROGRESS.md for this branch live in .claude/branches/${VIBE_BRANCH_SLUG}/ — read and write them there, never at .claude/ root, and create the directory if it does not exist. .claude/ is shared across all worktrees; only that subdirectory is yours. MEMORY.md and .claude/memory/ remain shared."$'\n\n'

if [[ -n "$PARENT_DIR" ]]; then
  SYSTEM_PROMPT+="Sibling repos available read-only at /repos/. Working project: $(realpath --relative-to="$PARENT_DIR" "$TARGET_DIR")."$'\n'
fi

TOOL_FLAGS=(--permission-mode auto --allow-dangerously-skip-permissions)
if [[ -n "$SYSTEM_PROMPT" ]]; then
  TOOL_FLAGS+=(--append-system-prompt "$SYSTEM_PROMPT")
fi


if [[ ${#EXTRA_ARGS[@]} -gt 0 ]]; then
  "${EXEC[@]}" /entrypoint.sh claude "${TOOL_FLAGS[@]}" "${EXTRA_ARGS[@]}"
else
  "${EXEC[@]}" /entrypoint.sh claude --continue "${TOOL_FLAGS[@]}" \
    || "${EXEC[@]}" /entrypoint.sh claude "${TOOL_FLAGS[@]}"
fi

clear

# Tear down container before worktree removal so the mount is released
if [[ -n "$WORKTREE" ]] && ! ((KEEP)); then
  remove_container
  rm -f "$VSCODE_FIFO" "$VSCODE_FIFO_RESP" "$BROWSER_FIFO"
  TORN_DOWN=1
fi

# Prompt to remove worktree if one was created
if [[ -n "$WORKTREE" ]]; then
  read -rp "Remove worktree '$WORKTREE_BRANCH'? [y/N] " answer
  if [[ "$answer" == [yY] ]]; then
    git worktree remove "$WORKTREE" 2>/dev/null || rm -rf "$WORKTREE"
    echo "Worktree '$WORKTREE_BRANCH' removed."
  fi
fi

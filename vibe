#!/usr/bin/env bash

set -e

tolower() { echo "$1" | tr '[:upper:]' '[:lower:]'; }

IS_MACOS=0
[[ "$(uname -s)" == "Darwin" ]] && IS_MACOS=1

# Default modes
DEBUG=0
BUILD=0
DOWN=0
KEEP=0
TORN_DOWN=0
VSCODE=0
NO_CACHE=0
GITIGNORE_ON=0
GITIGNORE_OFF=0
PARENT_DIR=""

usage() {
  cat <<'EOF'
Usage: vibe [flags] [directory] [-- args...]

Flags:
  -B    Build the container image before starting
  -d    Tear down the container and exit
  -D    Debug mode (shell into the container)
  -g    Force .claude/.gitignore on (add '*' entry)
  -G    Force .claude/.gitignore off (remove '*' entry)
  -h    Show this help message
  -k    Keep container running on exit
  -N    Build with no cache (implies -B)
  -P    Mount parent directory read-only for sibling repo access
  -v    Open VS Code attached to the container
EOF
  exit 0
}

# Parse flags
while getopts "BdDgGhkNP:v" opt; do
  case $opt in
    B) BUILD=1;;
    d) DOWN=1;;
    D) DEBUG=1;;
    g) GITIGNORE_ON=1;;
    G) GITIGNORE_OFF=1;;
    h) usage;;
    k) KEEP=1;;
    N) NO_CACHE=1; BUILD=1;;
    P) PARENT_DIR="$(realpath -- "$OPTARG")";;
    v) VSCODE=1;;
    *) usage;;
  esac
done
shift $((OPTIND - 1))

# Split positional args at -- separator
WORKTREE=""
WORKTREE_BRANCH=""
EXTRA_ARGS=()
if [[ "${1:-}" == "--" ]]; then
  # No directory arg, rest goes to tool
  shift
  EXTRA_ARGS=("$@")
  TARGET_DIR="$PWD"
elif [[ "${1:-}" == w:* ]]; then
  # Git worktree mode: create/reuse a worktree under .w/
  WORKTREE_BRANCH="${1#w:}"
  WORKTREE_BASE="$(git rev-parse --show-toplevel)/.w"

  mkdir -p "$WORKTREE_BASE"

  WORKTREE="${WORKTREE_BASE}/${WORKTREE_BRANCH}"
  if [[ -d "$WORKTREE" ]] && [[ ! -f "$WORKTREE/.git" ]]; then
    read -rp "Stale directory '$WORKTREE_BRANCH' exists but is not a valid worktree. Remove and re-create? [y/N] " answer
    if [[ "$answer" == [yY] ]]; then
      rm -rf "$WORKTREE"
    else
      echo "Cannot proceed without a valid worktree." >&2
      exit 1
    fi
  fi
  if [[ ! -d "$WORKTREE" ]]; then
    if git show-ref --verify --quiet "refs/heads/$WORKTREE_BRANCH"; then
      git worktree add "$WORKTREE" "$WORKTREE_BRANCH"
    else
      git worktree add -b "$WORKTREE_BRANCH" "$WORKTREE"
    fi
  fi

  # Mount the entire repo so git worktree paths resolve inside the container
  TARGET_DIR="$(git rev-parse --show-toplevel)"
  WORKTREE_REL=".w/${WORKTREE_BRANCH}"
  shift
  if [[ "${1:-}" == "--" ]]; then
    shift
  fi
  EXTRA_ARGS=("$@")
elif [[ -z "${1:-}" ]] || [[ "${1:-}" == -* ]]; then
  # No directory arg; anything remaining is tool args
  TARGET_DIR="$PWD"
  if [[ "${1:-}" == "--" ]]; then
    shift
  fi
  EXTRA_ARGS=("$@")
else
  TARGET_DIR="$(realpath -- "$1")"
  shift
  if [[ "${1:-}" == "--" ]]; then
    shift
  fi
  EXTRA_ARGS=("$@")
fi
if [[ ! -d "$TARGET_DIR" ]]; then
  echo "Error: '$TARGET_DIR' is not a directory" >&2
  exit 1
fi
export TARGET_DIR

if [[ -n "$PARENT_DIR" ]]; then
  if [[ ! -d "$PARENT_DIR" ]]; then
    echo "Error: parent directory '$PARENT_DIR' does not exist" >&2
    exit 1
  fi
  case "$TARGET_DIR" in
    "$PARENT_DIR"/*) ;;
    *) echo "Error: '$TARGET_DIR' is not inside '$PARENT_DIR'" >&2; exit 1;;
  esac
fi

# Ensure .claude/ exists and mount it
if [[ -n "$WORKTREE" ]]; then
  VIBE_DIR="$(git rev-parse --show-toplevel)/.claude"
else
  VIBE_DIR="${TARGET_DIR}/.claude"
fi
VIBE_DIR_EXISTED=0
[[ -d "$VIBE_DIR" ]] && VIBE_DIR_EXISTED=1
mkdir -p "$VIBE_DIR"
GITIGNORE="$VIBE_DIR/.gitignore"
if ((GITIGNORE_ON)); then
  grep -qxF '*' "$GITIGNORE" 2>/dev/null || echo '*' >> "$GITIGNORE"
elif ((GITIGNORE_OFF)); then
  if [[ -f "$GITIGNORE" ]]; then
    sed -i '/^[[:space:]]*\*[[:space:]]*$/d' "$GITIGNORE"
    if ! grep -q '[^[:space:]]' "$GITIGNORE" 2>/dev/null; then
      rm -f "$GITIGNORE"
    fi
  fi
elif ! ((VIBE_DIR_EXISTED)); then
  echo '*' > "$GITIGNORE"
fi
export VIBE_DIR

# Inject/update a managed section in .claude/CLAUDE.md
# Usage: inject_section "## Heading" "content"
inject_section() {
  local heading="$1" content="$2"
  local claude_md="$VIBE_DIR/CLAUDE.md"
  local block
  block="$(printf '%s\n\n%s' "$heading" "$content")"

  if [[ ! -f "$claude_md" ]]; then
    printf '%s\n' "$block" > "$claude_md"
    return
  fi

  if ! grep -qF "$heading" "$claude_md"; then
    printf '\n\n%s\n' "$block" >> "$claude_md"
    return
  fi

  awk -v heading="$heading" -v block="$block" '
    $0 == heading { skip=1; printf "%s\n\n", block; next }
    skip && /^## / { skip=0 }
    !skip { print }
  ' "$claude_md" > "$claude_md.tmp" && mv "$claude_md.tmp" "$claude_md"
}

# Inject personal rules
read -r -d '' DEFAULT_RULES <<'RULES' || true
- Challenge user decisions when you see a better approach.
- Simple and clean over hacky or overengineered.
- If deviating from the plan, stop and discuss first.
- Small steps: max ~300 lines per step, one reviewable commit each. Ask before the next.
- Comments: max 2 lines, only when why isn't obvious; prefer none. No decorative comments, banners, or ASCII art.
- Never commit unless asked. Suggest a conventional commit command (under 80 chars). One approval ≠ blanket permission.
- Never push to remote.
RULES

RULES_FILE="$HOME/.claude-docker/rules.md"
if [[ -f "$RULES_FILE" ]]; then
  RULES_CONTENT="$(cat "$RULES_FILE")"
  if echo "$RULES_CONTENT" | grep -q '^##'; then
    echo "Error: $RULES_FILE contains '##' headings which would break the section delimiter" >&2
    exit 1
  fi
else
  RULES_CONTENT="$DEFAULT_RULES"
fi
inject_section "## Personal Rules (maintained by the vibe utility)" "$RULES_CONTENT"

# Inject environment context
read -r -d '' ENV_CONTENT <<'ENV' || true
Disposable Ubuntu Docker container with passwordless sudo. Install freely.
After installing a tool, append its directory to ~/.bin-paths.
At session start, run: export PATH="$(cat ~/.bin-paths 2>/dev/null | tr '\n' ':'):$PATH"

Save project context in .claude/ (PLAN.md, PROGRESS.md at root; MEMORY.md and per-memory files under .claude/memory/). .claude/ is bind-mounted from the parent repo, persists across worktrees. Max 150 lines per file.
ENV
inject_section "## Environment (maintained by the vibe utility)" "$ENV_CONTENT"

# Ensure graphify-out/ exists and mount it
if [[ -n "$WORKTREE" ]]; then
  GRAPHIFY_DIR="$(git rev-parse --show-toplevel)/graphify-out"
else
  GRAPHIFY_DIR="${TARGET_DIR}/graphify-out"
fi
mkdir -p "$GRAPHIFY_DIR"
if [[ ! -f "$GRAPHIFY_DIR/.gitignore" ]]; then
  echo '*' > "$GRAPHIFY_DIR/.gitignore"
fi
export GRAPHIFY_DIR

# Sanitize a string to only contain alphanumeric characters and hyphens
sanitize() { echo "$1" | tr -cd "a-zA-Z0-9-"; }

# Base docker arguments
DIR_HASH="$(echo -n "$TARGET_DIR" | md5sum | cut -c1-4)"
DIR_BASENAME="$(sanitize "$(basename "$TARGET_DIR")")"

# Set terminal/tmux window name early (before slow docker run)
if [[ -n "$WORKTREE_BRANCH" ]]; then
  WINDOW_TITLE="w:${DIR_BASENAME}:${WORKTREE_BRANCH}"
else
  WINDOW_TITLE="v:${DIR_BASENAME}"
fi
TMUX_WINDOW=""
if [[ -n "${TMUX:-}" ]]; then
  TMUX_WINDOW="$(tmux display-message -p '#{window_id}')"
  tmux rename-window -t "$TMUX_WINDOW" "$WINDOW_TITLE"
else
  printf '\033]0;%s\007' "$WINDOW_TITLE"
fi

# For worktrees, include the branch name (DIR_BASENAME is already the repo name)
if [[ -n "$WORKTREE" ]]; then
  BRANCH_BASENAME="$(sanitize "$WORKTREE_BRANCH")"
  PROJECT_NAME="vibe-${DIR_BASENAME}-${BRANCH_BASENAME}-${DIR_HASH}"
else
  PROJECT_NAME="vibe-${DIR_BASENAME}-${DIR_HASH}"
fi

PROJECT_NAME="$(tolower "$PROJECT_NAME")"
export PROJECT_NAME

# Mount .claude inside the worktree CWD so Claude can find it
if [[ -n "${WORKTREE_REL:-}" ]]; then
  export VIBE_MOUNT="${TARGET_DIR}/${WORKTREE_REL}/.claude"
else
  export VIBE_MOUNT="${TARGET_DIR}/.claude"
fi

# Mount graphify-out inside the worktree CWD
if [[ -n "${WORKTREE_REL:-}" ]]; then
  export GRAPHIFY_MOUNT="${TARGET_DIR}/${WORKTREE_REL}/graphify-out"
else
  export GRAPHIFY_MOUNT="${TARGET_DIR}/graphify-out"
fi

GID=$(id -g)
export GID

IMAGE_NAME="vibe-base"
CONTAINER_NAME="${PROJECT_NAME}"

ENTRYPOINT_SCRIPT='#!/bin/bash

if [[ -S /tmp/ssh_auth_sock ]]; then
  export SSH_AUTH_SOCK=/tmp/ssh_auth_sock
fi

if [[ -S /tmp/gnupg_sock ]]; then
  sudo chmod 666 /tmp/gnupg_sock
  gpgconf --kill gpg-agent 2>/dev/null || true
  GNUPG_SOCK=$(gpgconf --list-dir agent-socket)
  mkdir -m 700 -p "$(dirname "$GNUPG_SOCK")"
  ln -sf /tmp/gnupg_sock "$GNUPG_SOCK"
fi

if [[ -n "${GPG_PUBKEYS:-}" && ! -f /tmp/.gpg_keys_imported ]]; then
  gpgconf --kill keyboxd 2>/dev/null || true
  echo "$GPG_PUBKEYS" | gpg --batch --no-autostart --import 2>/dev/null || true
  gpg --batch --no-autostart --list-keys --with-colons 2>/dev/null \
    | awk -F: '"'"'/^fpr:/{print $10":6:"}'"'"' \
    | gpg --batch --no-autostart --import-ownertrust 2>/dev/null || true
  gpgconf --kill keyboxd 2>/dev/null || true
  touch /tmp/.gpg_keys_imported
fi

if [[ -f /tmp/host_gitconfig ]]; then
  ln -sf /tmp/host_gitconfig "$HOME/.gitconfig"
fi

if [[ -f /tmp/host_claude_json ]]; then
  ln -sf /tmp/host_claude_json "$HOME/.claude.json"
else
  if [[ ! -f "$HOME/.claude/claude.json" ]]; then
    echo '"'"'{}'"'"' > "$HOME/.claude/claude.json"
  fi
  ln -sf "$HOME/.claude/claude.json" "$HOME/.claude.json"
fi

if [[ "${VIBE_VSCODE:-}" == "1" ]]; then
  mkdir -p /tmp/vscode_queue /tmp/vscode_resp
fi
if [[ "${VIBE_BROWSER:-}" == "1" ]]; then
  mkdir -p /tmp/browser_queue
fi
if [[ "${VIBE_CLIPBOARD:-}" == "1" ]]; then
  mkdir -p /tmp/clipboard_queue /tmp/clipboard_resp
fi

if [[ -p /tmp/vscode_fifo ]] || [[ -d /tmp/vscode_queue ]]; then
  export EDITOR="code -w"
fi

if [[ -p /tmp/browser_fifo ]] || [[ -d /tmp/browser_queue ]]; then
  export BROWSER="xdg-open"
fi

node -e "
  var fs = require('"'"'fs'"'"'), f = process.env.HOME + '"'"'/.claude.json'"'"';
  var d = JSON.parse(fs.readFileSync(f, '"'"'utf8'"'"'));
  var p = d.projects = d.projects || {}, dir = process.cwd();
  if (!p[dir] || !p[dir].hasTrustDialogAccepted) {
    p[dir] = Object.assign(p[dir] || {}, {hasTrustDialogAccepted: true, hasCompletedProjectOnboarding: true});
    fs.writeFileSync(f, JSON.stringify(d, null, 2));
  }
" 2>/dev/null || true

if [[ -n "${WORKDIR:-}" ]]; then
  sudo mkdir -p "$WORKDIR" && sudo chown $(id -u):$(id -g) "$WORKDIR"
  cd "$WORKDIR"
fi

if [[ -n "${ON_BUILD:-}" && ! -f /tmp/.on_build_done ]]; then
  eval "$ON_BUILD"
  touch /tmp/.on_build_done
fi

if [[ ! -f /tmp/.graphify_installed ]]; then
  graphify install &>/dev/null || true
  touch /tmp/.graphify_installed
fi

exec "$@"
'

CODE_WRAPPER='#!/bin/bash
ARGS=()
WAIT=0
for arg in "$@"; do
  if [[ "$arg" == "-w" || "$arg" == "--wait" ]]; then
    WAIT=1
    ARGS+=("$arg")
  elif [[ "$arg" == -* ]]; then
    ARGS+=("$arg")
  else
    ARGS+=("$(realpath "$arg")")
  fi
done
if [[ -d /tmp/vscode_queue ]]; then
  ID="$$.$RANDOM"
  printf '"'"'%s\0'"'"' "${ARGS[@]}" > "/tmp/vscode_queue/${ID}"
  if [[ "$WAIT" -eq 1 ]]; then
    for _ in $(seq 1 300); do
      [[ -f "/tmp/vscode_resp/${ID}" ]] && { rm -f "/tmp/vscode_resp/${ID}"; exit 0; }
      sleep 0.1
    done
  fi
elif [[ -p /tmp/vscode_fifo ]]; then
  printf '"'"'%s\0'"'"' "${ARGS[@]}" > /tmp/vscode_fifo
  if [[ "$WAIT" -eq 1 ]]; then
    read -r < /tmp/vscode_fifo_resp
  fi
fi
'

BROWSER_WRAPPER='#!/bin/bash
for arg in "$@"; do
  if [[ -d /tmp/browser_queue ]]; then
    echo "$arg" > "/tmp/browser_queue/$$.$RANDOM"
  elif [[ -p /tmp/browser_fifo ]]; then
    echo "$arg" > /tmp/browser_fifo
  fi
done
'

CLIPBOARD_WRAPPER='#!/bin/bash
if [[ -d /tmp/clipboard_queue ]]; then
  IPC=queue
elif [[ -p /tmp/clipboard_fifo ]]; then
  IPC=fifo
else
  exit 1
fi
TYPE="image/png"
IS_READ=0
LIST=0
case "$(basename "$0")" in wl-paste) IS_READ=1 ;; esac
while [[ $# -gt 0 ]]; do
  case "$1" in
    -o|--output) IS_READ=1; shift ;;
    -l|--list-types) LIST=1; IS_READ=1; shift ;;
    -t|--type) TYPE="$2"; shift 2 ;;
    *) shift ;;
  esac
done
((IS_READ)) || exit 0
ID="$$.$RANDOM"
if ((LIST)) || [[ "$TYPE" == "TARGETS" ]]; then
  REQ="LIST"
else
  REQ="$TYPE"
fi
if [[ "$IPC" == "queue" ]]; then
  echo "$REQ" > "/tmp/clipboard_queue/${ID}"
else
  echo "${ID} ${REQ}" > /tmp/clipboard_fifo
fi
RESP="/tmp/clipboard_resp/${ID}"
for _ in $(seq 1 50); do
  [[ -f "$RESP" ]] && { cat "$RESP"; rm -f "$RESP"; exit 0; }
  sleep 0.1
done
'

read -r -d '' DOCKERFILE <<'DOCKERFILE_EOF' || true
FROM debian:latest

RUN apt-get update -y \
  && apt-get upgrade -y \
  && apt-get install -y --no-install-recommends \
    curl build-essential git sudo docker.io openssh-client gnupg nodejs npm python3 python3-dev iproute2 socat \
  && rm -rf /var/lib/apt/lists/*

ENV USER=dev
ENV GIT_SSH_COMMAND="ssh -o StrictHostKeyChecking=no"
ARG UID=1000
ARG GID=1000
RUN groupdel $(getent group $GID | cut -d: -f1) 2>/dev/null || true \
  && groupadd -g $GID $USER \
  && useradd -mG sudo -g $USER -s /bin/bash -u $UID $USER \
  && echo "$USER ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/$USER

USER $USER
WORKDIR /tmp

RUN mkdir -p \
  /home/$USER/.local/bin \
  /home/$USER/.local/state/claude \
  /home/$USER/.claude

RUN curl -fsSL https://claude.ai/install.sh | bash \
  && curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/home/$USER/.local/bin:$PATH"
RUN uv tool install graphifyy

ARG CODE_WRAPPER
RUN echo "$CODE_WRAPPER" > /home/$USER/.local/bin/code \
  && chmod +x /home/$USER/.local/bin/code

ARG BROWSER_WRAPPER
RUN echo "$BROWSER_WRAPPER" > /home/$USER/.local/bin/xdg-open \
  && chmod +x /home/$USER/.local/bin/xdg-open

ARG CLIPBOARD_WRAPPER
RUN echo "$CLIPBOARD_WRAPPER" > /home/$USER/.local/bin/xclip \
  && chmod +x /home/$USER/.local/bin/xclip \
  && ln -s xclip /home/$USER/.local/bin/xsel \
  && ln -s xclip /home/$USER/.local/bin/wl-paste

ARG ENTRYPOINT
RUN echo "$ENTRYPOINT" | sudo tee /entrypoint.sh > /dev/null \
  && sudo chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]

CMD ["bash", "-c", "sleep infinity"]
DOCKERFILE_EOF

# In worktree mode, mount parent repo as read-only
if [[ -n "$WORKTREE" ]]; then
  VOLUME_RO=":ro"
fi

export DOCKER_CONTEXT=default

get_container_id() {
  docker ps -qf "name=^${CONTAINER_NAME}$"
}

# Use XDG_RUNTIME_DIR for FIFOs so they survive /tmp cleanups (systemd-tmpfiles)
FIFO_DIR="${XDG_RUNTIME_DIR:-/tmp}"

# Tear down the container and exit if requested
if ((DOWN)); then
  docker rm -f "$CONTAINER_NAME" &>/dev/null || true
  while docker inspect "$CONTAINER_NAME" &>/dev/null; do sleep 0.1; done
  rm -f "${FIFO_DIR}"/vibe-vscode-"${PROJECT_NAME}"-*.fifo "${FIFO_DIR}"/vibe-browser-"${PROJECT_NAME}"-*.fifo "${FIFO_DIR}"/vibe-clipboard-"${PROJECT_NAME}"-*.fifo
  rm -rf "${FIFO_DIR}"/vibe-clipboard-resp-"${PROJECT_NAME}"-*
  # Clean up socat port-forwarding state
  if [[ -f "/tmp/.vibe-socat-pids-${PROJECT_NAME}" ]]; then
    while read -r pid _; do kill "$pid" 2>/dev/null || true; done < "/tmp/.vibe-socat-pids-${PROJECT_NAME}"
    rm -f "/tmp/.vibe-socat-pids-${PROJECT_NAME}"
  fi
  rm -f /tmp/.vibe-socat-"${PROJECT_NAME}"-*
  exit 0
fi

# Setup the GPG extra socket.
# The extra socket is more restricted than the normal socket
if command -v gpgconf &>/dev/null; then
  GNUPG_SOCK=$(gpgconf --list-dir agent-extra-socket)
  if [[ -S "$GNUPG_SOCK" ]]; then
    export GNUPG_SOCK
    GPG_PUBKEYS=$(gpg --export -a $(gpg --list-secret-keys --with-colons | awk -F: '/^sec/{print $5}'))
    export GPG_PUBKEYS
  fi
fi

# Setup gitconfig if it exists
if [[ -f "$HOME/.gitconfig" ]]; then
  export GITCONFIG="$HOME/.gitconfig"
fi

# Detect host capabilities
HAS_CODE=0
command -v code &>/dev/null && HAS_CODE=1

if command -v open &>/dev/null; then
  OPEN_CMD="open"
elif command -v xdg-open &>/dev/null; then
  OPEN_CMD="xdg-open"
else
  OPEN_CMD=""
fi

if command -v wl-paste &>/dev/null; then
  CLIP_CMD="wl-paste"
elif command -v xclip &>/dev/null; then
  CLIP_CMD="xclip"
elif command -v pbpaste &>/dev/null; then
  CLIP_CMD="pbpaste"
else
  CLIP_CMD=""
fi

# Setup IPC bridges (FIFOs on Linux, queue dirs polled via docker exec on macOS)
VSCODE_FIFO="" VSCODE_FIFO_RESP="" BROWSER_FIFO="" CLIPBOARD_FIFO="" CLIPBOARD_RESP_DIR=""
if ! ((IS_MACOS)); then
  FIFO_ID="$(head -c4 /dev/urandom | od -An -tx1 | tr -d ' ')"

  if ((HAS_CODE)); then
    VSCODE_FIFO="${FIFO_DIR}/vibe-vscode-${PROJECT_NAME}-${FIFO_ID}.fifo"
    VSCODE_FIFO_RESP="${FIFO_DIR}/vibe-vscode-${PROJECT_NAME}-${FIFO_ID}-resp.fifo"
    for fifo in "$VSCODE_FIFO" "$VSCODE_FIFO_RESP"; do
      mkfifo "$fifo"
      chmod 600 "$fifo"
    done
  fi

  if [[ -n "$OPEN_CMD" ]]; then
    BROWSER_FIFO="${FIFO_DIR}/vibe-browser-${PROJECT_NAME}-${FIFO_ID}.fifo"
    mkfifo "$BROWSER_FIFO"
    chmod 600 "$BROWSER_FIFO"
  fi

  if [[ -n "$CLIP_CMD" ]]; then
    CLIPBOARD_FIFO="${FIFO_DIR}/vibe-clipboard-${PROJECT_NAME}-${FIFO_ID}.fifo"
    mkfifo "$CLIPBOARD_FIFO"
    chmod 600 "$CLIPBOARD_FIFO"
    CLIPBOARD_RESP_DIR="${FIFO_DIR}/vibe-clipboard-resp-${PROJECT_NAME}-${FIFO_ID}"
    mkdir -p "$CLIPBOARD_RESP_DIR"
    chmod 700 "$CLIPBOARD_RESP_DIR"
  fi
fi
export VSCODE_FIFO VSCODE_FIFO_RESP BROWSER_FIFO CLIPBOARD_FIFO CLIPBOARD_RESP_DIR


# Check if the user has an on_build.sh script in ~/.vibe
ON_BUILD_SCRIPT="$HOME/.claude-docker/on_build.sh"
if [[ -f "$ON_BUILD_SCRIPT" ]]; then
  ON_BUILD="$(cat "$ON_BUILD_SCRIPT")"
  export ON_BUILD
fi

CLAUDE_HOME="${HOME}/.claude"
CLAUDE_STATE="${HOME}/.local/state/claude"
CLAUDE_PROJECTS="${VIBE_DIR}/.projects"
mkdir -p "$CLAUDE_HOME" "$CLAUDE_STATE" "$CLAUDE_PROJECTS"

# Migrate existing conversation history to project-local storage (one-time)
PROJECT_KEY="$(echo "$TARGET_DIR" | sed 's/[^a-zA-Z0-9]/-/g')"
HOST_PROJECT_DIR="${CLAUDE_HOME}/projects/${PROJECT_KEY}"
if [[ -d "$HOST_PROJECT_DIR" ]] && [[ ! -d "${CLAUDE_PROJECTS}/${PROJECT_KEY}" ]]; then
  mv "$HOST_PROJECT_DIR" "${CLAUDE_PROJECTS}/${PROJECT_KEY}"
fi

CLAUDE_JSON="${HOME}/.claude.json"
if [[ ! -f "$CLAUDE_JSON" ]]; then
  echo '{}' > "$CLAUDE_JSON"
fi

# Build volumes array
VOLUMES=(
  -v "$TARGET_DIR:$TARGET_DIR${VOLUME_RO:-}"
  -v /var/run/docker.sock:/var/run/docker.sock
  -v "${SSH_AUTH_SOCK:-/dev/null}:/tmp/ssh_auth_sock"
  -v "${GNUPG_SOCK:-/dev/null}:/tmp/gnupg_sock"
  -v "${GITCONFIG:-/dev/null}:/tmp/host_gitconfig"
  -v "${CLAUDE_JSON}:/tmp/host_claude_json"
  -v "${CLAUDE_HOME}:/home/dev/.claude"
  -v "${CLAUDE_PROJECTS}:/home/dev/.claude/projects"
  -v "${CLAUDE_STATE}:/home/dev/.local/state/claude"
  -v "$VIBE_DIR:$VIBE_MOUNT"
  -v "$GRAPHIFY_DIR:$GRAPHIFY_MOUNT"
)
if ! ((IS_MACOS)); then
  VOLUMES+=(
    -v "${VSCODE_FIFO:-/dev/null}:/tmp/vscode_fifo"
    -v "${VSCODE_FIFO_RESP:-/dev/null}:/tmp/vscode_fifo_resp"
    -v "${BROWSER_FIFO:-/dev/null}:/tmp/browser_fifo"
    -v "${CLIPBOARD_FIFO:-/dev/null}:/tmp/clipboard_fifo"
    -v "${CLIPBOARD_RESP_DIR:-/dev/null}:/tmp/clipboard_resp"
  )
fi
if [[ -n "$WORKTREE" ]]; then
  VOLUMES+=(-v "$TARGET_DIR/.git:$TARGET_DIR/.git")
  VOLUMES+=(-v "$TARGET_DIR/$WORKTREE_REL:$TARGET_DIR/$WORKTREE_REL")
fi
if [[ -n "$PARENT_DIR" ]]; then
  VOLUMES+=(-v "$PARENT_DIR:/repos:ro")
fi

remove_container() {
  docker rm -f "$CONTAINER_NAME" &>/dev/null || true
  while docker inspect "$CONTAINER_NAME" &>/dev/null; do sleep 0.1; done
}

remove_container

build_image() {
  docker build -t "$IMAGE_NAME" \
    --build-arg "UID=$(id -u)" \
    --build-arg "GID=$(id -g)" \
    --build-arg "ENTRYPOINT=$ENTRYPOINT_SCRIPT" \
    --build-arg "CODE_WRAPPER=$CODE_WRAPPER" \
    --build-arg "BROWSER_WRAPPER=$BROWSER_WRAPPER" \
    --build-arg "CLIPBOARD_WRAPPER=$CLIPBOARD_WRAPPER" \
    "$@" - <<< "$DOCKERFILE"
}

if ((BUILD)); then
  if ((NO_CACHE)); then
    build_image --no-cache
  else
    build_image
  fi
elif ! docker image inspect "$IMAGE_NAME" &>/dev/null; then
  build_image
fi

ENVS=(
  -e "GPG_PUBKEYS=${GPG_PUBKEYS:-}"
  -e "WORKDIR=${TARGET_DIR}"
  -e "ON_BUILD=${ON_BUILD:-}"
)
if ((IS_MACOS)); then
  ((HAS_CODE)) && ENVS+=(-e "VIBE_VSCODE=1")
  [[ -n "$OPEN_CMD" ]] && ENVS+=(-e "VIBE_BROWSER=1")
  [[ -n "$CLIP_CMD" ]] && ENVS+=(-e "VIBE_CLIPBOARD=1")
fi

docker run -d --name "$CONTAINER_NAME" \
  --network bridge \
  "${ENVS[@]}" \
  "${VOLUMES[@]}" \
  "$IMAGE_NAME" bash -c "sleep infinity" >/dev/null

# Forward container listening ports to host via socat (for OAuth callbacks etc.)
PORT_WATCHER_PID=""
if command -v socat &>/dev/null; then
  (
    while true; do
      sleep 1
      CID="$(get_container_id 2>/dev/null)" || continue
      [[ -n "$CID" ]] || continue
      CURRENT="$(docker exec "$CID" ss -tln 2>/dev/null | awk 'NR>1 {split($4,a,":"); print a[length(a)]}' | sort -u)"
      [[ -n "$CURRENT" ]] || continue
      for PORT in $CURRENT; do
        [[ "$PORT" =~ ^[0-9]+$ ]] || continue
        MARKER="/tmp/.vibe-socat-${PROJECT_NAME}-${PORT}"
        [[ -f "$MARKER" ]] && continue
        touch "$MARKER"
        socat "TCP-LISTEN:${PORT},reuseaddr,fork" "EXEC:docker exec -i ${CID} socat STDIO TCP\:127.0.0.1\:${PORT}" 2>/dev/null &
        echo "$! $PORT" >> "/tmp/.vibe-socat-pids-${PROJECT_NAME}"
      done
    done
  ) &
  PORT_WATCHER_PID=$!
  disown
elif [[ ! -f "$HOME/.claude-docker/.no-socat-warning" ]]; then
  echo "Warning: 'socat' is not installed. OAuth login callback won't work."
  echo "Install it with your package manager (e.g. sudo pacman -S socat)."
  read -rp "Continue? [Y/n/never] " ans
  case "$(tolower "$ans")" in
    n|no) exit 1 ;;
    never) mkdir -p "$HOME/.claude-docker" && touch "$HOME/.claude-docker/.no-socat-warning" ;;
  esac
fi

# Helper to open VS Code attached to the container
open_vscode() {
  local container_id path hex_id
  container_id="$(get_container_id)"
  path="${1:-$TARGET_DIR}"
  hex_id="$(printf '%s' "$container_id" | od -A n -t x1 | tr -d ' \n')"
  code --folder-uri "vscode-remote://attached-container+${hex_id}${path}"
}

# Process a VS Code request (NUL-delimited args)
handle_vscode_request() {
  local args_raw="$1" reply_func="$2"
  local container_id hex_id uri_base
  container_id="$(get_container_id)"
  hex_id="$(printf '%s' "$container_id" | od -A n -t x1 | tr -d ' \n')"
  uri_base="vscode-remote://attached-container+${hex_id}"

  local flags=() paths=() all_args=()
  while IFS= read -r -d '' arg; do all_args+=("$arg"); done < <(printf '%s' "$args_raw")
  for arg in "${all_args[@]}"; do
    if [[ "$arg" == -* ]]; then flags+=("$arg"); else paths+=("$arg"); fi
  done

  local code_args=("${flags[@]}") has_folder=0
  for path in "${paths[@]}"; do
    if docker exec "$container_id" test -d "$path" 2>/dev/null; then
      has_folder=1
      code_args+=("--folder-uri" "${uri_base}${path}")
    else
      code_args+=("--file-uri" "${uri_base}${path}")
    fi
  done
  if [[ "$has_folder" -eq 0 ]]; then
    code_args+=("--folder-uri" "${uri_base}${TARGET_DIR}")
  fi

  code "${code_args[@]}"
  if [[ " ${flags[*]} " == *" -w "* || " ${flags[*]} " == *" --wait "* ]]; then
    eval "$reply_func"
  fi
}

PBPASTE_IMG_CACHE=""

# Read host clipboard content
read_host_clipboard() {
  local req="$1" outfile="$2"
  if [[ "$req" == "LIST" ]]; then
    if [[ "$CLIP_CMD" == "pbpaste" ]]; then
      local info types=""
      PBPASTE_IMG_CACHE=""
      info=$(osascript -e 'clipboard info' 2>/dev/null) || info=""
      if [[ "$info" == *"«class PNGf»"* ]] || [[ "$info" == *"«class TIFF»"* ]]; then
        types="image/png"
        PBPASTE_IMG_CACHE="$(mktemp)"
        osascript -l JavaScript -e '
          ObjC.import("AppKit");
          ObjC.import("Foundation");
          var pb = $.NSPasteboard.generalPasteboard;
          var data = pb.dataForType("public.png");
          if (!data || data.isNil()) {
            var tiffData = pb.dataForType("public.tiff");
            if (tiffData && !tiffData.isNil()) {
              var rep = $.NSBitmapImageRep.imageRepWithData(tiffData);
              if (rep && !rep.isNil()) {
                data = rep.representationUsingTypeProperties(4, $.NSDictionary.dictionary);
              }
            }
          }
          if (data && !data.isNil()) {
            data.writeToFileAtomically("'"$PBPASTE_IMG_CACHE"'", true);
          }
        ' &>/dev/null
        [[ -s "$PBPASTE_IMG_CACHE" ]] || { rm -f "$PBPASTE_IMG_CACHE"; PBPASTE_IMG_CACHE=""; types=""; }
      fi
      if [[ "$info" == *"«class utf8»"* ]]; then
        types="${types:+$types
}text/plain"
      fi
      echo "${types:-text/plain}" > "${outfile}.tmp"
    elif [[ "$CLIP_CMD" == "wl-paste" ]]; then
      wl-paste -l 2>/dev/null > "${outfile}.tmp" || echo -n > "${outfile}.tmp"
    else
      xclip -selection clipboard -t TARGETS -o 2>/dev/null > "${outfile}.tmp" || echo -n > "${outfile}.tmp"
    fi
  else
    if [[ "$CLIP_CMD" == "pbpaste" ]]; then
      if [[ "$req" == "image/png" ]] && [[ -n "$PBPASTE_IMG_CACHE" ]] && [[ -s "$PBPASTE_IMG_CACHE" ]]; then
        cp "$PBPASTE_IMG_CACHE" "${outfile}.tmp"
        rm -f "$PBPASTE_IMG_CACHE"
        PBPASTE_IMG_CACHE=""
      elif [[ "$req" == "image/png" ]]; then
        echo -n > "${outfile}.tmp"
      else
        pbpaste 2>/dev/null > "${outfile}.tmp" || echo -n > "${outfile}.tmp"
      fi
    elif [[ "$CLIP_CMD" == "wl-paste" ]]; then
      wl-paste --type "$req" 2>/dev/null > "${outfile}.tmp" || echo -n > "${outfile}.tmp"
    else
      xclip -selection clipboard -t "$req" -o 2>/dev/null > "${outfile}.tmp" || echo -n > "${outfile}.tmp"
    fi
  fi
  mv "${outfile}.tmp" "$outfile"
}

# Start background watchers
WATCHER_PID=""
BROWSER_WATCHER_PID=""
CLIPBOARD_WATCHER_PID=""

if ((IS_MACOS)); then
  # macOS: poll container queue dirs via docker exec
  CID="$CONTAINER_NAME"

  if ((HAS_CODE)); then
    (
      while true; do
        sleep 0.5
        files="$(docker exec "$CID" ls /tmp/vscode_queue/ 2>/dev/null)" || continue
        for f in $files; do
          args_raw="$(docker exec "$CID" cat "/tmp/vscode_queue/$f" 2>/dev/null)" || continue
          docker exec "$CID" rm -f "/tmp/vscode_queue/$f" 2>/dev/null
          handle_vscode_request "$args_raw" "docker exec $CID touch /tmp/vscode_resp/$f"
        done
      done
    ) &
    WATCHER_PID=$!
    disown
  fi

  if [[ -n "$OPEN_CMD" ]]; then
    (
      while true; do
        sleep 0.5
        files="$(docker exec "$CID" ls /tmp/browser_queue/ 2>/dev/null)" || continue
        for f in $files; do
          url="$(docker exec "$CID" cat "/tmp/browser_queue/$f" 2>/dev/null)" || continue
          docker exec "$CID" rm -f "/tmp/browser_queue/$f" 2>/dev/null
          [[ -n "$url" ]] && $OPEN_CMD "$url" &>/dev/null &
        done
      done
    ) &
    BROWSER_WATCHER_PID=$!
    disown
  fi

  if [[ -n "$CLIP_CMD" ]]; then
    (
      while true; do
        sleep 0.5
        files="$(docker exec "$CID" ls /tmp/clipboard_queue/ 2>/dev/null)" || continue
        for f in $files; do
          req="$(docker exec "$CID" cat "/tmp/clipboard_queue/$f" 2>/dev/null)" || continue
          docker exec "$CID" rm -f "/tmp/clipboard_queue/$f" 2>/dev/null
          [[ -n "$req" ]] || continue
          tmpfile="$(mktemp)"
          read_host_clipboard "$req" "$tmpfile"
          docker exec -i "$CID" tee "/tmp/clipboard_resp/$f" < "$tmpfile" >/dev/null
          rm -f "$tmpfile"
        done
      done
    ) &
    CLIPBOARD_WATCHER_PID=$!
    disown
  fi

else
  # Linux: read from FIFOs directly
  if ((HAS_CODE)); then
    (
      while [[ -p "$VSCODE_FIFO" ]]; do
        if args_raw=$(cat "$VSCODE_FIFO" 2>/dev/null) && [[ -n "$args_raw" ]]; then
          handle_vscode_request "$args_raw" "echo done > $VSCODE_FIFO_RESP"
        fi
      done
    ) &
    WATCHER_PID=$!
    disown
  fi

  if [[ -n "$OPEN_CMD" ]]; then
    (
      while [[ -p "$BROWSER_FIFO" ]]; do
        if read -r url < "$BROWSER_FIFO" 2>/dev/null; then
          $OPEN_CMD "$url" &>/dev/null &
        fi
      done
    ) &
    BROWSER_WATCHER_PID=$!
    disown
  fi

  if [[ -n "$CLIP_CMD" ]]; then
    (
      while [[ -p "$CLIPBOARD_FIFO" ]]; do
        if line=$(cat "$CLIPBOARD_FIFO" 2>/dev/null) && [[ -n "$line" ]]; then
          id="${line%% *}"
          req="${line#* }"
          read_host_clipboard "$req" "${CLIPBOARD_RESP_DIR}/${id}"
        fi
      done
    ) &
    CLIPBOARD_WATCHER_PID=$!
    disown
  fi
fi

# Clean up watcher on exit
cleanup() {
  if [[ -n "$TMUX_WINDOW" ]]; then
    tmux set-option -w -t "$TMUX_WINDOW" automatic-rename on
  else
    printf '\033]0;\007'
  fi
  if [[ -n "$WATCHER_PID" ]]; then
    kill "$WATCHER_PID" 2>/dev/null || true
  fi
  if [[ -n "$BROWSER_WATCHER_PID" ]]; then
    kill "$BROWSER_WATCHER_PID" 2>/dev/null || true
  fi
  if [[ -n "$CLIPBOARD_WATCHER_PID" ]]; then
    kill "$CLIPBOARD_WATCHER_PID" 2>/dev/null || true
  fi
  if [[ -n "$PORT_WATCHER_PID" ]]; then
    kill "$PORT_WATCHER_PID" 2>/dev/null || true
  fi
  if [[ -f "/tmp/.vibe-socat-pids-${PROJECT_NAME}" ]]; then
    while read -r pid _; do kill "$pid" 2>/dev/null || true; done < "/tmp/.vibe-socat-pids-${PROJECT_NAME}"
    rm -f "/tmp/.vibe-socat-pids-${PROJECT_NAME}"
  fi
  rm -f /tmp/.vibe-socat-"${PROJECT_NAME}"-*
  if ! ((KEEP)) && ! ((TORN_DOWN)); then
    remove_container
    rm -f "$VSCODE_FIFO" "$VSCODE_FIFO_RESP" "$BROWSER_FIFO" "$CLIPBOARD_FIFO"
    rm -rf "$CLIPBOARD_RESP_DIR"
  fi
}
trap cleanup EXIT

# Open VS Code if requested via -v flag
if ((VSCODE)); then
  if ! ((HAS_CODE)); then
    echo "Error: 'code' command not found on host" >&2
    exit 1
  fi
  open_vscode "$TARGET_DIR"
fi

# Set up exec command
if [[ -n "${WORKTREE_REL:-}" ]]; then
  WORKDIR="${TARGET_DIR}/${WORKTREE_REL}"
else
  WORKDIR="${TARGET_DIR}"
fi
EXEC=(docker exec -it -w "$WORKDIR" "$CONTAINER_NAME")

# Shell into the container if in debug mode
if ((DEBUG)); then
  "${EXEC[@]}" /entrypoint.sh bash
  exit 0
fi

# Run Claude Code in the container
SYSTEM_PROMPT=""

if [[ -n "$WORKTREE" ]]; then
  read -r -d '' _PROMPT <<EOF || true
You are working inside a git worktree for branch '$WORKTREE_BRANCH' at $WORKDIR.
The parent repository is mounted read-only — only this worktree directory and .git/ are writable.
You may read parent files (e.g. to compare against main), but do not attempt to modify them.
EOF
  SYSTEM_PROMPT+="$_PROMPT"
fi

if [[ -n "$PARENT_DIR" ]]; then
  SYSTEM_PROMPT+="Sibling repos available read-only at /repos/. Working project: $(realpath --relative-to="$PARENT_DIR" "$TARGET_DIR")."
fi

TOOL_FLAGS=(--dangerously-skip-permissions --permission-mode plan)
if [[ -n "$SYSTEM_PROMPT" ]]; then
  TOOL_FLAGS+=(--append-system-prompt "$SYSTEM_PROMPT")
fi


if [[ ${#EXTRA_ARGS[@]} -gt 0 ]]; then
  "${EXEC[@]}" /entrypoint.sh claude "${TOOL_FLAGS[@]}" "${EXTRA_ARGS[@]}"
else
  "${EXEC[@]}" /entrypoint.sh claude --continue "${TOOL_FLAGS[@]}" \
    || "${EXEC[@]}" /entrypoint.sh claude "${TOOL_FLAGS[@]}"
fi

clear

# Tear down container before worktree removal so the mount is released
if [[ -n "$WORKTREE" ]] && ! ((KEEP)); then
  remove_container
  rm -f "$VSCODE_FIFO" "$VSCODE_FIFO_RESP" "$BROWSER_FIFO"
  TORN_DOWN=1
fi

# Prompt to remove worktree if one was created
if [[ -n "$WORKTREE" ]]; then
  read -rp "Remove worktree '$WORKTREE_BRANCH'? [y/N] " answer
  if [[ "$answer" == [yY] ]]; then
    git worktree remove "$WORKTREE" 2>/dev/null || rm -rf "$WORKTREE"
    echo "Worktree '$WORKTREE_BRANCH' removed."
  fi
fi

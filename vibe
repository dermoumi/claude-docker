# Process a VS Code request (NUL-delimited args)
handle_vscode_request() {
  local args_raw="$1" reply_func="$2"
  local container_id hex_id uri_base
  container_id="$(get_container_id)"
  hex_id="$(printf '%s' "$container_id" | od -A n -t x1 | tr -d ' \n')"
  uri_base="vscode-remote://attached-container+${hex_id}"

  local flags=() paths=() all_args=()
  while IFS= read -r -d '' arg; do all_args+=("$arg"); done < <(printf '%s' "$args_raw")
  for arg in "${all_args[@]}"; do
    if [[ "$arg" == -* ]]; then flags+=("$arg"); else paths+=("$arg"); fi
  done

  local code_args=("${flags[@]}") has_folder=0
  for path in "${paths[@]}"; do
    if docker exec "$container_id" test -d "$path" 2>/dev/null; then
      has_folder=1
      code_args+=("--folder-uri" "${uri_base}${path}")
    else
      code_args+=("--file-uri" "${uri_base}${path}")
    fi
  done
  if [[ "$has_folder" -eq 0 ]]; then
    code_args+=("--folder-uri" "${uri_base}${TARGET_DIR}")
  fi

  code "${code_args[@]}"
  if [[ " ${flags[*]} " == *" -w "* || " ${flags[*]} " == *" --wait "* ]]; then
    eval "$reply_func"
  fi
}


#!/usr/bin/env bash
# Run instead of `ssht devbox`: serve this machine's clipboard over a unix socket
# forwarded into the remote container, so Ctrl+V image paste works there.

LOCAL_SOCK="${HOME}/.vibe/clip.sock"
REMOTE_SOCK="/tmp/vibe-clip.sock"

detect_clip() {
  if command -v wl-paste &>/dev/null; then echo wl-paste
  elif command -v xclip &>/dev/null; then echo xclip
  elif command -v pbpaste &>/dev/null; then echo pbpaste
  fi
}

# Stateless: each socat connection is a fresh process, so render PNG on demand.
serve_pbpaste_png() {
  local tmp
  tmp="$(mktemp)"
  osascript -l JavaScript -e '
    ObjC.import("AppKit");
    ObjC.import("Foundation");
    var pb = $.NSPasteboard.generalPasteboard;
    var data = pb.dataForType("public.png");
    if (!data || data.isNil()) {
      var tiffData = pb.dataForType("public.tiff");
      if (tiffData && !tiffData.isNil()) {
        var rep = $.NSBitmapImageRep.imageRepWithData(tiffData);
        if (rep && !rep.isNil()) {
          data = rep.representationUsingTypeProperties(4, $.NSDictionary.dictionary);
        }
      }
    }
    if (data && !data.isNil()) {
      data.writeToFileAtomically("'"$tmp"'", true);
    }
  ' &>/dev/null
  [[ -s "$tmp" ]] && cat "$tmp"
  rm -f "$tmp"
}

# One request line on stdin ("LIST" or a mime type), raw bytes on stdout.
serve() {
  local req clip
  IFS= read -r req || return 0
  clip="$(detect_clip)"
  [[ -n "$clip" ]] || return 0
  if [[ "$req" == "LIST" ]]; then
    case "$clip" in
      pbpaste)
        local info types=""
        info=$(osascript -e 'clipboard info' 2>/dev/null) || info=""
        [[ "$info" == *"«class PNGf»"* || "$info" == *"«class TIFF»"* ]] && types="image/png"
        [[ "$info" == *"«class utf8»"* ]] && types="${types:+$types
}text/plain"
        echo "${types:-text/plain}"
        ;;
      wl-paste) wl-paste -l 2>/dev/null ;;
      xclip)    xclip -selection clipboard -t TARGETS -o 2>/dev/null ;;
    esac
  else
    case "$clip" in
      pbpaste)
        if [[ "$req" == "image/png" ]]; then serve_pbpaste_png
        else pbpaste 2>/dev/null; fi
        ;;
      wl-paste) wl-paste --type "$req" 2>/dev/null ;;
      xclip)    xclip -selection clipboard -t "$req" -o 2>/dev/null ;;
    esac
  fi
}

if [[ "${1:-}" == "--serve" ]]; then
  serve
  exit 0
fi

command -v socat &>/dev/null || { echo "devbox: socat is required" >&2; exit 1; }
[[ -n "$(detect_clip)" ]] || \
  echo "devbox: no clipboard tool (wl-paste/xclip/pbpaste); paste will be unavailable" >&2

mkdir -p "$(dirname "$LOCAL_SOCK")"
rm -f "$LOCAL_SOCK"
socat "UNIX-LISTEN:${LOCAL_SOCK},fork,mode=600" "EXEC:$(realpath "$0") --serve" &
SERVE_PID=$!
trap 'kill "$SERVE_PID" 2>/dev/null; rm -f "$LOCAL_SOCK"' EXIT

# kitten ssh (via ssht) shares connections, and a reused master drops new -R
# forwards; ControlPath=none forces a private connection so the socket binds.
ssht -o ControlPath=none -R "${REMOTE_SOCK}:${LOCAL_SOCK}" "$@" devbox
